{
  "name": "ripple",
  "displayName": "Ripple — Live Change Impact",
  "description": "팀원이 함수·타입·스키마를 바꾸면, 그게 네 코드의 어디를 어떻게 깨는지 저장(라이브)·PR 시점에 찔러줍니다. 의존그래프 기반(설정 0).",
  "version": "0.2.4",
  "publisher": "k08200",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Visualization"
  ],
  "keywords": [
    "impact analysis",
    "team",
    "change notification",
    "dependency",
    "live",
    "collaboration"
  ],
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0b7285",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/k08200/ripple.git"
  },
  "bugs": {
    "url": "https://github.com/k08200/ripple/issues"
  },
  "homepage": "https://github.com/k08200/ripple#readme",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Ripple",
      "properties": {
        "ripple.backendUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:7077",
          "description": "Ripple 백엔드 WebSocket URL (로컬은 127.0.0.1 권장 — 윈도우의 localhost IPv6 우선 해석 함정 회피)"
        },
        "ripple.userId": {
          "type": "string",
          "default": "",
          "description": "팀에서 나를 식별하는 이름 (비우면 OS 사용자명)"
        },
        "ripple.secret": {
          "type": "string",
          "default": "",
          "description": "공유 백엔드 인증 토큰 (백엔드 RIPPLE_SECRET 과 일치). 비우면 인증 없음(로컬용)."
        },
        "ripple.autoStartBrain": {
          "type": "boolean",
          "default": true,
          "description": "backendUrl 이 로컬이고 두뇌가 안 떠 있으면 자동으로 띄운다 (설치만 하면 됨). 팀 공용 두뇌를 쓰면 backendUrl 을 원격으로 두면 자동기동 안 함."
        },
        "ripple.team": {
          "type": "string",
          "default": "",
          "description": "팀 room (공용 백엔드에서 같은 값끼리만 서로 본다). 비우면 git 원격 주소에서 자동 도출 — 같은 repo 면 자동으로 같은 팀."
        },
        "ripple.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "backendUrl 을 따로 안 정하면 같은 와이파이(LAN)에서 두뇌를 자동으로 찾아 붙는다. 고정 IP 불필요 — host 가 바뀌어도 따라감. 끄면 로컬만."
        },
        "ripple.watchPRs": {
          "type": "boolean",
          "default": true,
          "description": "열린 PR 의 변경 영향도 변경 피드에 띄운다(저장 기준 + PR 게이트). GitHub 로그인을 사용(추가 토큰 0). 끄면 저장 기준만."
        }
      }
    },
    "commands": [
      {
        "command": "ripple.demo",
        "title": "Ripple: 데모 — 가상 동료 변경 시뮬레이트"
      },
      {
        "command": "ripple.refreshPrs",
        "title": "Ripple: 열린 PR 영향 새로고침"
      },
      {
        "command": "ripple.reconnect",
        "title": "Ripple: 백엔드 재연결"
      },
      {
        "command": "ripple.reindex",
        "title": "Ripple: 워크스페이스 재인덱싱"
      },
      {
        "command": "ripple.showFeed",
        "title": "Ripple: 변경 피드 열기"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ripple",
          "title": "Ripple",
          "icon": "media/ripple.svg"
        }
      ]
    },
    "views": {
      "ripple": [
        {
          "id": "ripple.feed",
          "name": "변경 피드",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --outfile=dist/extension.js",
    "bundle:brain": "esbuild ../backend/src/server.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/brain.js",
    "build": "npm run typecheck && npm run bundle && npm run bundle:brain",
    "test": "node --no-warnings --test test/*.mjs",
    "watch": "npm run bundle -- --watch",
    "vscode:prepublish": "npm run build",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish ripple.vsix"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
