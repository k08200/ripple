# Ripple 로컬 키 — 이 파일을 .env 로 복사하고 값 채우기. .env 는 gitignore 됨.
# OpenRouter (OpenAI 호환). LLM/hybrid provider 가 이 키를 쓴다.
OPENROUTER_API_KEY=sk-or-...

# (선택) 모델 지정. 기본: anthropic/claude-3.5-sonnet
# 예: anthropic/claude-sonnet-4 · openai/gpt-4o · google/gemini-2.0-flash-001
# RIPPLE_MODEL=anthropic/claude-3.5-sonnet

# (선택) Anthropic 직접 키 (OpenRouter 대신)
# ANTHROPIC_API_KEY=sk-ant-...
